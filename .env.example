# ==========================================
# FACULTY SCHEDULING SYSTEM (DEPLOYMENT ENV)
# ==========================================

# 1. APPLICATION SETTINGS
# ------------------------------------------
# Set this to "production" in Vercel to trigger optimized error handling 
# and secure middleware configurations.
NODE_ENV=production

# The port Express will listen on (usually handled by Vercel automatically)
PORT=5001

# JWT Secret Key for authenticating users. Ensure this is strong, 
# long, and kept highly secure across the team.
JWT_SECRET=generate_a_very_long_secure_random_string_here

# 2. VERCEL-SPECIFIC SETTINGS
# ------------------------------------------
# Set to '1' logically, though Vercel injects this automatically. 
# Our backend uses this flag to safely bypass Realtime Socket connections 
# since Vercel Serverless Functions do not support persistent WebSockets.
VERCEL=1

# 3. DATABASE CONFIGURATION (EXTERNAL MYSQL)
# ------------------------------------------
# Since Vercel Serverless environments do not have persistent storage, 
# you MUST connect to a Cloud MySQL provider like Aiven, PlanetScale, or Railway.
# Ask your cloud provider for these credentials:
DB_HOST=your-cloud-database-hostname.com
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=faculty_scheduling_db

# 4. EMAIL SERVICE (OTP / Notifications)
# ------------------------------------------
# SMTP credentials for sending faculty alerts and OTP verification emails
# You can use Brevo (Sendinblue), Mailgun, or standard Gmail App Passwords
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587 
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-smtp-password
FROM_EMAIL="Faculty Scheduler <noreply@yourdomain.com>"
